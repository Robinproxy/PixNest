# Shared secret for X-Auth-Token (required in production)
AUTH_TOKEN=change-me-to-a-strong-secret

# Optional: public base URL for generated image links (e.g. https://img.example.com/)
PUBLIC_BASE_URL=

# Optional: comma-separated list of allowed Host headers (e.g. img.example.com,localhost)
ALLOWED_HOSTS=

# Optional: comma-separated list of trusted proxy IPs that may set X-Forwarded-For / CF-Connecting-IP
TRUSTED_PROXIES=

# Max upload size in megabytes
MAX_UPLOAD_MB=10

# Expired-file cleanup interval in seconds
CLEANUP_INTERVAL_SEC=600
